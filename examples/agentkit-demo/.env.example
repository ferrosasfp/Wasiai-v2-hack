WASIAI_CONTRACT_ADDRESS=0x71CddCdF8a40951a1d8C22C8774448FbcA089b53
# USDC en Fuji testnet
USDC_FUJI_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65

# ─── Demo ─────────────────────────────────────────────────────────────────────
